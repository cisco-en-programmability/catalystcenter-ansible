---
warn_list: []
skip_list:
  # Skip non-critical formatting and style rules for v2.7.0 release
  # These can be addressed in future releases
  - yaml[trailing-spaces]
  - yaml[line-length]
  - yaml[comments]
  - yaml[comments-indentation]
  - yaml[document-start]
  - yaml[new-line-at-end-of-file]
  - yaml[truthy]
  - yaml[colons]
  - yaml[commas]
  - yaml[empty-lines]
  - yaml[hyphens]
  - yaml[indentation]
  - yaml[anchors]  # Anchors defined in parent playbooks
  - var-naming[no-role-prefix]  # Connection vars are standardized across collection
  - fqcn[action-core]  # Implicit FQCN is acceptable
  - jinja[spacing]  # Template spacing is functional
  - name[casing]  # Task naming conventions
  - name[template]  # Jinja in task names
  - name[missing]  # Some tasks don't need names
  - risky-file-permissions  # File permissions are context-dependent
  - no-changed-when  # Changed_when not always needed
  - run-once[task]  # Run-once is valid pattern
  - schema[meta]  # Meta schema variations are acceptable
  - yaml[key-duplicates]  # Will be addressed separately

exclude_paths:
  - playbooks/image_details.yml
  - playbooks/input_events_and_notification.yml
  - playbooks/sda_fabric.yml
  - tests
  - playbooks/credentials.yml
  - .github/workflows
  - cvp/sda_device_removal_and_unprovision/playbook/tasks/remove_single_device.yml
